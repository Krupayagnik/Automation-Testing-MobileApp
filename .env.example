# ============================================================
# FILE: .env.example
# PURPOSE: Template for environment variables
# STEPS: Copy this file and rename it to ".env"
#        Then fill in your real values
# WARNING: Never commit the real .env file to GitHub!
# ============================================================

# ── App Settings ─────────────────────────────────────────────
APP_URL=https://begenuin.com

# ── Test Account Credentials ─────────────────────────────────
# Create a DEDICATED test account for automation
# NEVER use real user accounts for testing!
TEST_PHONE=9876543210
TEST_EMAIL=testuser@example.com
TEST_PASSWORD=Test@1234
TEST_USERNAME=test_user_qa
TEST_OTP=123456

# ── CI Settings ──────────────────────────────────────────────
CI=false
